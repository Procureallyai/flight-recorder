# Secret value must be injected through 1Password Environments. Never persist a real key here.
OPENAI_API_KEY=managed-by-1password-environments

# Non-secret runtime controls.
OPENAI_MODEL=gpt-5.6
FLIGHT_RECORDER_REVIEW_ENABLED=false
FLIGHT_RECORDER_MAX_REVIEW_CALLS=5
FLIGHT_RECORDER_MAX_OUTPUT_TOKENS=2000
